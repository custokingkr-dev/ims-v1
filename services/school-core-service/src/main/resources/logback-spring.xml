<configuration>
    <springProperty scope="context" name="serviceName" source="spring.application.name" defaultValue="custoking-service"/>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp/>
                <logLevel/>
                <loggerName/>
                <threadName/>
                <mdc/>
                <message/>
                <stackTrace/>
                <pattern>
                    <pattern>{"service":"${serviceName}"}</pattern>
                </pattern>
                <pattern>
                    <pattern>
                        {
                          "severity": "%level",
                          "logging.googleapis.com/trace": "projects/${GCP_PROJECT:-custoking}/traces/%mdc{traceId:-}",
                          "logging.googleapis.com/spanId": "%mdc{spanId:-}"
                        }
                    </pattern>
                </pattern>
            </providers>
        </encoder>
    </appender>
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
