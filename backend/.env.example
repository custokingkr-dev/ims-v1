# ─────────────────────────────────────────────────────────────────────────────
# Custoking IMS — Backend environment variables reference
# Copy this file to .env (gitignored) for local development.
# In production (Cloud Run), inject all variables via GCP Secret Manager or
# Cloud Run env-var settings.  Never commit a populated .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Active Spring profile ─────────────────────────────────────────────────────
# Use "dev" locally (swagger enabled, verbose SQL logging).
# Use "prod" in every deployed environment.
SPRING_PROFILES_ACTIVE=dev


# ── Database — application connection (least-privilege) ──────────────────────
# This user must have SELECT / INSERT / UPDATE / DELETE on every table.
# It must NOT have CREATE TABLE / ALTER / DROP rights.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/postgres
SPRING_DATASOURCE_USERNAME=ims_app
SPRING_DATASOURCE_PASSWORD=change_me


# ── Database — Flyway migration connection (DDL rights required) ──────────────
# Flyway runs schema migrations and needs CREATE TABLE / ALTER / DROP.
# Use a separate DBA/superuser account; never reuse the app account here.
# Defaults to the datasource URL/user if left unset (fine for local dev).
FLYWAY_URL=jdbc:postgresql://localhost:5432/postgres
FLYWAY_USERNAME=postgres
FLYWAY_PASSWORD=change_me


# ── Application secrets (REQUIRED — startup fails if absent or too short) ─────
# APP_JWT_SECRET   : HS256 signing key; must be ≥ 32 characters.
# APP_AADHAR_SECRET: AES encryption key for Aadhaar data; must be ≥ 16 characters.
# Generate with: openssl rand -hex 32
APP_JWT_SECRET=replace_with_at_least_32_chars_random_string_here
APP_AADHAR_SECRET=replace_with_16plus


# ── Bootstrap / demo data ─────────────────────────────────────────────────────
# Set APP_BOOTSTRAP_USERS=true only on the first deploy to seed the superadmin
# account and demo data.  Set it to false for all subsequent restarts.
APP_BOOTSTRAP_USERS=true

SUPERADMIN_EMAIL=superadmin@custoking.com
SUPERADMIN_PASSWORD=change_me_strong_password

# Optional: create a demo school admin account (only when this var is set).
# DEMO_ADMIN_PASSWORD=change_me_demo_password


# ── JWT & cookie settings ─────────────────────────────────────────────────────
# Token expiry in milliseconds (default: 86400000 = 24 h).
# APP_JWT_EXPIRATION_MS=86400000

# Must be true in production (HTTPS).  false is fine for localhost HTTP.
APP_COOKIE_SECURE=false


# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Default covers the Vite dev ports; override in production.
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173


# ── Swagger / OpenAPI ─────────────────────────────────────────────────────────
# false in production (default).  true only for controlled internal sessions.
# When true, /v3/api-docs and /swagger-ui require a valid JWT.
SWAGGER_ENABLED=false


# ── Connection pool tuning (optional — defaults are safe for most workloads) ──
# DB_POOL_MAX=10
# DB_POOL_MIN=2


# ── Server port ──────────────────────────────────────────────────────────────
# Cloud Run injects PORT automatically; do not hard-code 8080 in prod configs.
# PORT=8080
