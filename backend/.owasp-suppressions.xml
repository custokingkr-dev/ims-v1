<!--
  OWASP Dependency-Check suppression file.
  Add entries here for known-false-positives or temporarily accepted CVEs.
  Each suppression MUST include a documented rationale and expiry date.

  Format:
    <suppress until="YYYY-MM-DD">
      <notes>Reason: ... | Tracked: IMS-XXX | Review by: YYYY-MM-DD</notes>
      <cve>CVE-YYYY-XXXXX</cve>
    </suppress>

  Do NOT add suppressions without justification. All CRITICAL (CVSS >= 9)
  CVEs must be fixed or have an active suppression with an owner and deadline.
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

  <!--
    Example (replace with real suppressions as needed):

    <suppress until="2026-12-01">
      <notes>
        Reason: CVE-2023-XXXXX affects Spring Boot &lt;3.2 only; we run 3.4.x — false positive NVD CPE match.
        Tracked: IMS-101 | Owner: platform-team | Review: 2026-12-01
      </notes>
      <cve>CVE-2023-XXXXX</cve>
    </suppress>
  -->

</suppressions>
