<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ── Dev / default: human-readable coloured console ── -->
    <springProfile name="!prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%cyan(%thread)] [rid=%X{requestId:-}] %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.custoking" level="INFO"/>
        <logger name="org.flywaydb"  level="INFO"/>
    </springProfile>

    <!-- ── Production: structured JSON to stdout (collected by Cloud Logging) ── -->
<!-- ── Production: structured JSON to stdout (collected by Cloud Logging) ── -->
    <springProfile name="prod">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <immediateFlush>true</immediateFlush>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeCallerData>false</includeCallerData>
                <customFields>{"service":"custoking-ims"}</customFields>
                <includeMdcKeyName>requestId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <includeMdcKeyName>userEmail</includeMdcKeyName>
                <includeMdcKeyName>schoolId</includeMdcKeyName>
            </encoder>
        </appender>
    
        <root level="WARN">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
        <logger name="com.custoking" level="INFO"/>
        <logger name="org.flywaydb"  level="INFO"/>
    </springProfile>

</configuration>
